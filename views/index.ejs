<!DOCTYPE html>
<html>
  <head>
    <title>OpenArms - Recently Viewed Clients</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-1BmE4kWBq78iYhFldvKuhfTAU6auU8tT94WrHftjDbrCEXSU1oBoqyl2QvZ6jIW3" crossorigin="anonymous">

    <link rel='stylesheet' href='/stylesheets/style.css' />
  </head>
  <body>
    <div class="container">
      <h1>OpenArms</h1>
      <p>Staff Member: <strong><%= staffId %></strong></p>

      <section>
        <h2>View a Client</h2>
        <form action="/clients/add" method="POST">
          <div>
            <label class="form-label">
              Client ID: <input type="text" class="form-control" name="clientId" placeholder="e.g. c001">
            </label>

            <button class="btn btn-primary">View Client</button>
          </div>

        </form>
      </section>
      
      <section>
        <h2>Recently Viewed Clients (<%= recentClients.length %> / 10)</h2>
        <% if (recentClients.length === 0) { %>
          <p>No clients viewed yet.</p>
        <% } else { %>
          <% recentClients.forEach(function(clientId, index){ %>
            <div class="d-flex align-items-center mb-2">
              <span class="me-3">#<%= index + 1 %></span>
              <span class="me-3"><%= clientId %></span>
              <form action="/clients/<%= clientId %>/remove" method="POST">
                <button class="btn btn-danger btn-sm">Remove</button>
              </form>
            </div>
          <% }); %>
          <form action="/clients/clear" method="POST">
            <button class="btn btn-danger mt-3">Clear All</button>
          </form>
        <% } %>
      </section>
    </div>
  </body>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-ka7Sk0Gln4gmtz2MlQnikT1wXgYsOg+OMhuP+IlRH9sENBO0LRn5q+8nbTov4+1p" crossorigin="anonymous"></script>
</html>